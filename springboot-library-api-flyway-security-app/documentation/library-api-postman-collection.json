{
  "info": {
    "_postman_id": "12345678-1234-1234-1234-123456789012",
    "name": "Library API - Full Test Suite",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Comprehensive test suite for Library Management System API. Includes auth, librarian, and user endpoints with automated variable handling for JWT tokens and IDs."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "librarian_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "book_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01. Auth",
      "description": "Authentication endpoints for signup and login.",
      "item": [
        {
          "name": "Signup Librarian",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"librarian1\",\n    \"email\": \"librarian1@example.com\",\n    \"password\": \"Librarian123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "signup"]
            }
          },
          "response": []
        },
        {
          "name": "Login Librarian",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"librarian1\",\n    \"password\": \"Librarian123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "login"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"jwt_token\", response.token);",
                  "pm.environment.set(\"librarian_id\", response.id);",
                  "postman.setNextRequest(\"Signup User\");"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Signup User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"user1\",\n    \"email\": \"user1@example.com\",\n    \"password\": \"User123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/signup",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "signup"]
            }
          },
          "response": []
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"user1\",\n    \"password\": \"User123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "auth", "login"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"user_jwt_token\", response.token);",
                  "pm.environment.set(\"user_id\", response.id);",
                  "postman.setNextRequest(\"Librarian: Add Book\");"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02. Librarian Actions",
      "description": "Endpoints for librarian actions (book/user management).",
      "item": [
        {
          "name": "Add Book",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"The Great Gatsby\",\n    \"author\": \"F. Scott Fitzgerald\",\n    \"isbn\": \"9780743273565\",\n    \"totalCopies\": 5\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/librarian/books",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "librarian", "books"]
            }
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "pm.environment.set(\"book_id\", response.id);",
                  "postman.setNextRequest(\"Librarian: Get All Books\");"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/librarian/books",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "librarian", "books"]
            }
          },
          "response": []
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"The Great Gatsby (Updated)\",\n    \"author\": \"F. Scott Fitzgerald\",\n    \"isbn\": \"9780743273565\",\n    \"totalCopies\": 10\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/librarian/books/{{book_id}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "librarian", "books", "{{book_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/librarian/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "librarian", "users"]
            }
          },
          "response": []
        },
        {
          "name": "Update User Role",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"role\": \"LIBRARIAN\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/librarian/users/{{user_id}}/role",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "librarian", "users", "{{user_id}}", "role"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "03. User Actions",
      "description": "Endpoints for user actions (borrowing/returning books).",
      "item": [
        {
          "name": "Get Available Books",
